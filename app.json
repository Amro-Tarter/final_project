{
  "expo": {
    "name": "acheivments_ahead",
    "slug": "acheivments_ahead",
    "scheme": "acheivmentsahead",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-web-browser",
      "expo-router",
      "expo-notifications",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Inter-Bold.ttf",
            "./assets/fonts/Poppins-Bold.ttf",
            "./assets/fonts/Poppins-Regular.ttf"
          ]
        }
      ]
    ],
    "web": {
      "bundler": "metro"
    },
    "android": {
      "package": "com.acheivmentsahead.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F172A"
      },
      "userInterfaceStyle": "automatic"
    },
    "ios": {
      "bundleIdentifier": "com.acheivmentsahead.app"
    },
    "extra": {
      "eas": {
        "projectId": "a9f93193-09d5-4419-92c6-fd4d527ce5bc"
      }
    },
    "owner": "amro123",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/a9f93193-09d5-4419-92c6-fd4d527ce5bc"
    }
  }
}